{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "defaultBase": "main",
  "namedInputs": {},
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "build:deps": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build", "build:icons"],
      "cache": false
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:browser": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:browser:dev": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:compile": {
      "dependsOn": ["^build", "build:icons"],
      "cache": true
    },
    "test:cross-version:prepare": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:cross-version": {
      "dependsOn": ["^build", "test:cross-version:prepare"],
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/e2e/cross-version/**/*",
        "{projectRoot}/dev/cross-version/**/*",
        "{projectRoot}/cross-version.manifest.json",
        "{projectRoot}/cross-version.exclude.json"
      ]
    },
    "test:cross-version:update": {
      "dependsOn": ["^build", "test:cross-version:prepare"],
      "cache": false
    },
    "test:cross-version:dev": {
      "dependsOn": ["^build", "test:cross-version:prepare"],
      "cache": false
    },
    "test:dev": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["^build", "test:e2e:prepare"],
      "cache": true
    },
    "test:e2e:dev": {
      "dependsOn": ["^build", "test:e2e:prepare"],
      "cache": true
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:visual:update": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:visual": {
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}
