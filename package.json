{
  "name": "@mittwald/flow-next-project",
  "private": true,
  "version": "1.0.0",
  "packageManager": "yarn@4.0.1",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "components:dev": "nx run-many -t=components:dev:watch,build:watch --projects=@mittwald/flow-documentation,@mittwald/flow-components",
    "dev:init-githooks": "yarn dlx simple-git-hooks",
    "docs:dev": "nx run-many -t=docs:dev:watch,build:watch --projects=@mittwald/flow-documentation,@mittwald/flow-components",
    "format": "prettier --write '**/*.{ts,tsx,yaml,yml,json,md,mdx,js,cjs,mjs,css}'",
    "lint": "eslint .",
    "test": "nx run-many --all -t test"
  },
  "simple-git-hooks": {
    "post-checkout": "yarn install",
    "post-merge": "yarn install",
    "pre-commit": "yarn lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "nx": "17.1.3",
    "nx-cloud": "^16.5.2",
    "prettier": "^3.1.0",
    "prettier-plugin-jsdoc": "^1.1.1",
    "prettier-plugin-pkgsort": "^0.2.1",
    "prettier-plugin-sort-json": "^3.1.0",
    "simple-git-hooks": "^2.9.0",
    "typescript": "^5.3.2"
  },
  "resolutions": {
    "@storybook/react": "^7.6.3",
    "@vitejs/plugin-react": "^4.2.1"
  },
  "dependenciesMeta": {
    "@types/react": {
      "unplugged": true
    },
    "react-aria-components": {
      "unplugged": true
    },
    "ts-node": {
      "unplugged": true
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
