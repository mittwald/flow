  "devDependencies": {
    "@fortawesome/sharp-regular-svg-icons": "npm:@fortawesome/free-regular-svg-icons@^7.2.0",
    "@mittwald/flow-icons-base": "workspace:*",
    "@types/react": "^19.2",
    "react": "^19.2.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "@fortawesome/sharp-regular-svg-icons": "^7.2.0",
    "react": "^19.2.0"
