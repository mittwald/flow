{
  "name": "@mittwald/flow-icons",
  "version": "0.2.0-alpha.745",
  "type": "module",
  "description": "Default iconset for Flow, mittwald’s design system",
  "homepage": "https://mittwald.github.io/flow",
  "repository": "https://github.com/mittwald/flow",
  "exports": {
    ".": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/esm/components/index.js"
    }
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:icons": "tsx src/dev/generate.ts",
    "clean": "rimraf dist src/components/*"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.40.0"
  },
  "devDependencies": {
    "@mittwald/flow-icons-base": "workspace:*",
    "@types/react": "^19.2",
    "react": "^19.2.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  }
}
